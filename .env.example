# Copy these into your Vercel project's Environment Variables (Settings → Environment Variables).
# Do NOT commit real values to GitHub.

# Required — your Anthropic API key (starts with sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Strongly recommended — a password YOU make up. The app must send it in the
# x-app-key header, so random people can't hit your endpoint and spend your credit.
APP_SECRET=make-up-a-long-random-string

# Optional — lock the API to only your site's address once you know it.
# Leave unset (or *) while testing.
# ALLOWED_ORIGIN=https://your-closeassist-site.com

# Optional — switch models. Cheaper: claude-haiku-4-5-20251001
# Confirm current strings at https://docs.claude.com/en/docs/about-claude/models
# MODEL=claude-sonnet-4-6
